{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ÆTHER",
  "mainBinaryName": "aether",
  "version": "1.0.27",
  "identifier": "com.canur.aether",
  "build": {
    "beforeDevCommand": "bun run dev:vite",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "bun run build:vite",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ÆTHER",
        "width": 1360,
        "height": 860,
        "minWidth": 1080,
        "minHeight": 680,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app"
    ],
    "icon": [
      "../resources/icon.png",
      "../build/icon.icns",
      "../build/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "dmg": {
        "background": "../build/dmg-background.png",
        "windowSize": {
          "width": 660,
          "height": 420
        },
        "appPosition": {
          "x": 180,
          "y": 270
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 270
        }
      }
    }
  }
}
